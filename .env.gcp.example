# ─────────────────────────────────────────────────────────────────────
# Hibi Matcha — Google Cloud env vars (copy → .env.gcp + fill in)
# ─────────────────────────────────────────────────────────────────────
# Source of truth for actual values: ~/.config/hibi-matcha/credentials.env
# (mode 600, outside repo, generated by Sprint 0 setup)
#
# This file documents the env shape. Do NOT commit .env.gcp with real secrets.
# ─────────────────────────────────────────────────────────────────────

# ── GCP project ──
GCS_PROJECT_ID=hibi-matcha-prod
GCS_PROJECT_NUMBER=168873510808
GCS_REGION=asia-southeast1

# ── Cloud Storage ──
GCS_BUCKET=hibimatcha-data-prod
# Future: cdn.hibimatcha.love (Cloud CDN — Sprint 1)
GCS_PUBLIC_URL_BASE=https://storage.googleapis.com/hibimatcha-data-prod

# ── Cloud SQL ──
# For local dev: use Cloud SQL Auth Proxy
#   ./cloud-sql-proxy hibi-matcha-prod:asia-southeast1:hibi-matcha-db &
#   DATABASE_URL=mysql://hibimatcha_app:<password>@127.0.0.1:3306/hibi_matcha
# For Cloud Run: connector socket auto-mounted at /cloudsql/<connection_name>
CLOUD_SQL_CONNECTION_NAME=hibi-matcha-prod:asia-southeast1:hibi-matcha-db
CLOUD_SQL_PUBLIC_IP=34.142.228.57
CLOUD_SQL_DB_NAME=hibi_matcha
CLOUD_SQL_USER=hibimatcha_app
CLOUD_SQL_PASSWORD=__from_credentials.env__

# ── Auth strategy ──
# Local dev: ADC via `gcloud auth application-default login`
# Production (Cloud Run): SA attached via `gcloud run services update --service-account=...`
# No SA key file required (org policy `iam.disableServiceAccountKeyCreation` enforced)
GCP_SA_EMAIL=hibimatcha-app@hibi-matcha-prod.iam.gserviceaccount.com

# ── OpenAI (Sprint 2 — replaces Manus Forge for AI features) ──
OPENAI_API_KEY=__set_in_sprint_2__
